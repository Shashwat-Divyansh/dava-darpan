# ---- Copy this file to server/.env and fill in real values (local dev) ----
# In production (Render), set these in the dashboard instead of a file.

# Port the Express API listens on.
# Local: 5001 (not 5000 — macOS AirPlay uses it). Render injects its own PORT.
PORT=5001

# MongoDB connection string (local MongoDB shown; use an Atlas URI in production).
MONGO_URI=mongodb://127.0.0.1:27017/dava-darpan

# Secret used to sign JWT auth tokens. Use a long, random string in real use.
JWT_SECRET=change-me-to-a-long-random-string

# How long issued JWTs stay valid.
JWT_EXPIRES_IN=7d

# Allowed frontend origin for CORS. Defaults to http://localhost:5173 if unset.
# In production, set this to your deployed Vercel URL (no trailing slash),
# e.g. https://dava-darpan.vercel.app
CLIENT_URL=http://localhost:5173

# Set to "production" on Render. This switches the auth cookie to
# sameSite=none + secure=true so it works cross-domain over HTTPS.
# Leave unset (or "development") locally.
NODE_ENV=development
