# ---- Copy this file to server/.env and fill in real values ----

# Port the Express API listens on
# (5001, not 5000: on macOS port 5000 is used by the AirPlay Receiver)
PORT=5001

# MongoDB connection string (local MongoDB shown; swap for Atlas URI if needed)
MONGO_URI=mongodb://127.0.0.1:27017/dava-darpan

# Secret used to sign JWT auth tokens (used in Phase 2 — auth).
# Use a long, random string in real use.
JWT_SECRET=change-me-to-a-long-random-string

# How long issued JWTs stay valid
JWT_EXPIRES_IN=7d
