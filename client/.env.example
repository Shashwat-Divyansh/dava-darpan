# ---- Copy to client/.env (or client/.env.local) for local overrides ----
# In production (Vercel), set this in the project's Environment Variables.

# Full URL of the deployed backend API, INCLUDING the /api suffix.
# Example (production): https://dava-darpan-api.onrender.com/api
#
# Leave this UNSET for local development — the app falls back to "/api", which
# the Vite dev proxy forwards to the local Express server on port 5001.
VITE_API_URL=
